{
  "name": "m3u8-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Extract m3u8 playlist URLs and playback headers from pages using Playwright Extra stealth.",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "start:football": "node index.js serve 3000 \"*/30 * * * *\"",
    "start:film": "node film-index.js serve 3001",
    "crawl:film": "node film-index.js crawl --force",
    "extract": "node index.js",
    "install:browsers": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
