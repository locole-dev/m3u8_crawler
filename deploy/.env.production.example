# Copy to .env on the VPS: cp deploy/.env.production.example .env

# Football (port 3000)
PORT=3000
CRON_SCHEDULE=*/30 * * * *
HEADLESS=true
TIMEOUT_MS=45000

# Film (port 3001)
FILM_PORT=3001
FILM_HEADLESS=true
FILM_TIMEOUT_MS=120000
FILM_COLLECT_MS=1500
FILM_MATCH_TIMEOUT_MS=900000
FILM_CRAWL_GAP_MS=1500
FILM_SKIP_STARTUP_CRAWL=false
FILM_OUTPUT_DIR=/data/film

HOST=0.0.0.0
NODE_OPTIONS=--unhandled-rejections=warn
